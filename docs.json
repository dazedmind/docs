{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "RLink Documentation",
  "colors": {
    "primary": "#0D44AE",
    "light": "#2681e0",
    "dark": "#2681e0"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "R Land website",
          "icon": "laptop",
          "href": "https://rlandph.vercel.app"
        },
        {
          "anchor": "RLink app",
          "icon": "globe",
          "href": "https://rlink-dev.vercel.app"
        },
        {
          "anchor": "Source",
          "icon": "github",
          "href": "https://github.com/dazedmind/rlink"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "guides/getting-started",
              "guides/r-link-quickstart",
              "guides/r-land-website-quickstart",
              "guides/dashboard-overview",
              "guides/deployment"
            ]
          },
          {
            "group": "System design",
            "pages": [
              "reference/architecture",
              "reference/proxy-and-request-flow",
              "reference/sitemap",
              "reference/database-schema"
            ]
          },
          {
            "group": "Security",
            "pages": [
              "auth/authentication-guide",
              "auth/authorization-and-modules"
            ]
          },
          {
            "group": "Operations",
            "pages": [
              "operations/troubleshooting",
              "operations/maintenance"
            ]
          },
          {
            "group": "Development",
            "pages": [
              "guides/domain-libraries",
              "guides/testing",
              "guides/email-and-notifications"
            ]
          },
          {
            "group": "UI and styling",
            "pages": [
              "styling/styling-and-design-system",
              {
                "group": "Components",
                "pages": [
                  "styling/components/input",
                  "styling/components/select",
                  "styling/components/file-upload"
                ]
              }
            ]
          },
          {
            "group": "Documentation site",
            "pages": [
              "guides/site-settings",
              "guides/site-navigation"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "api-reference/overview",
              "api-reference/webhooks"
            ]
          },
          {
            "group": "Mintlify OpenAPI examples",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/light.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Changelog",
        "href": "https://github.com/dazedmind/rlink/blob/main/CHANGELOG.md"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/dazedmind/rlink"
    }
  }
}
